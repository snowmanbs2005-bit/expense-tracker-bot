# Скопируйте этот файл в .env и подставьте свой токен.
#   cp .env.example .env
#
# Токен выдаёт @BotFather в Telegram: команда /newbot -> имя -> username -> токен.
BOT_TOKEN=123456789:AAExampleTokenReplaceMeWithRealOne

# Необязательно: путь к файлу базы данных SQLite (по умолчанию expenses.db).
DB_PATH=expenses.db

# Необязательно: часовой пояс для напоминаний в формате IANA (по умолчанию системный).
# TZ=Europe/Moscow
